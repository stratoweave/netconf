import testing
import xml
import netconf
from pipe import actor_pipe_pair

from fixups.openconfig_list_keys import XmlNav


def unwrap[T](a: ?T, msg: ?str=None) -> T:
    if a is not None:
        return a
    errmsg = msg if msg is not None else "Expected non-None value"
    raise ValueError(errmsg)


def has_openconfig_interface_key_name(reply: ?xml.Node) -> bool:
    if reply is None:
        return False
    root = unwrap(reply, "Expected xml.Node for reply")
    try:
        root.one("data", None).one("interfaces", None).one("interface", None).one("name", None)
    except ValueError:
        return False
    return True


def has_openconfig_subinterface_key_index(reply: ?xml.Node) -> bool:
    if reply is None:
        return False
    root = unwrap(reply, "Expected xml.Node for reply")
    try:
        root.one("data", None).one("interfaces", None).one("interface", None).one("subinterfaces", None).one("subinterface", None).one("index", None)
    except ValueError:
        return False
    return True


def broken_openconfig_interfaces_data() -> xml.Node:
    """Broken OpenConfig reply: list-entry keys are missing outside config."""
    return xml.decode(
        "<data xmlns=\"urn:ietf:params:xml:ns:netconf:base:1.0\">"
        + "<interfaces xmlns=\"http://openconfig.net/yang/interfaces\">"
        + "<interface>"
        + "<config>"
        + "<name>SC-1-3-C1</name>"
        + "<enabled>true</enabled>"
        + "</config>"
        + "<subinterfaces>"
        + "<subinterface>"
        + "<config>"
        + "<index>0</index>"
        + "</config>"
        + "</subinterface>"
        + "</subinterfaces>"
        + "<ethernet xmlns=\"http://openconfig.net/yang/interfaces/ethernet\"/>"
        + "</interface>"
        + "</interfaces>"
        + "</data>"
    )


def good_openconfig_interfaces_data() -> xml.Node:
    """Good OpenConfig reply: list-entry keys are present."""
    return xml.decode(
        "<data xmlns=\"urn:ietf:params:xml:ns:netconf:base:1.0\">"
        + "<interfaces xmlns=\"http://openconfig.net/yang/interfaces\">"
        + "<interface>"
        + "<name>SC-1-3-C1</name>"
        + "<config>"
        + "<name>SC-1-3-C1</name>"
        + "<enabled>true</enabled>"
        + "</config>"
        + "<subinterfaces>"
        + "<subinterface>"
        + "<index>0</index>"
        + "<config>"
        + "<index>0</index>"
        + "</config>"
        + "</subinterface>"
        + "</subinterfaces>"
        + "<ethernet xmlns=\"http://openconfig.net/yang/interfaces/ethernet\"/>"
        + "</interface>"
        + "</interfaces>"
        + "</data>"
    )


actor _test_openconfig_fixup_default_enabled(t: testing.EnvT):
    """Default fixups should repair missing OpenConfig list keys in replies."""
    pipes = actor_pipe_pair()

    caps = [
        netconf.CAP_NC_1_0,
        netconf.CAP_NC_1_1,
        "http://openconfig.net/yang/interfaces?module=openconfig-interfaces&revision=2019-11-19",
    ]

    def _on_connect(c: netconf.Client, e: ?Exception):
        if e is not None:
            t.failure(ValueError("Connection failed: {e}"))
            return
        c.get_config(_on_get_config)

    def _on_get_config(c: netconf.Client, result: ?xml.Node, error: ?netconf.NetconfError):
        if result is not None:
            t.success(result.encode(pretty=True))
        if error is not None:
            t.failure(ValueError("get-config failed: {error}"))

    def _on_server_rpc(s: netconf.Server, message_id: str, op: xml.Node):
        if op.tag == "get-config":
            s.send_reply(message_id, [broken_openconfig_interfaces_data()])
        else:
            s.send_error(message_id, "operation-not-supported", "Unsupported RPC operation: {op.tag}")

    server = netconf.Server(pipe=pipes.server, on_rpc=_on_server_rpc, capabilities=caps, log_handler=t.log_handler)
    client = netconf.Client(t.env.auth,
                            address="actor-pipe",
                            username="actor-pipe",
                            key=None,
                            password=None,
                            port=0,
                            on_connect=_on_connect,
                            on_notif=None,
                            log_handler=t.log_handler,
                            pipe=pipes.client)

    after 0.5: t.failure(ValueError("Timed out waiting for OpenConfig fixup test"))


actor _test_openconfig_fixup_disabled(t: testing.EnvT):
    """fixups=[] should disable all fixups."""
    pipes = actor_pipe_pair()

    caps = [
        netconf.CAP_NC_1_0,
        netconf.CAP_NC_1_1,
        "http://openconfig.net/yang/interfaces?module=openconfig-interfaces&revision=2019-11-19",
    ]

    def _on_connect(c: netconf.Client, e: ?Exception):
        if e is not None:
            t.failure(ValueError("Connection failed: {e}"))
            return
        c.get_config(_on_get_config)

    def _on_get_config(c: netconf.Client, result: ?xml.Node, error: ?netconf.NetconfError):
        if result is not None:
            t.success(result.encode(pretty=True))
            return
        if error is not None:
            t.failure(ValueError("get-config failed: {error}"))

    def _on_server_rpc(s: netconf.Server, message_id: str, op: xml.Node):
        if op.tag == "get-config":
            s.send_reply(message_id, [broken_openconfig_interfaces_data()])
        else:
            s.send_error(message_id, "operation-not-supported", "Unsupported RPC operation: {op.tag}")

    server = netconf.Server(pipe=pipes.server, on_rpc=_on_server_rpc, capabilities=caps, log_handler=t.log_handler)
    client = netconf.Client(t.env.auth,
                            address="actor-pipe",
                            username="actor-pipe",
                            key=None,
                            password=None,
                            port=0,
                            on_connect=_on_connect,
                            on_notif=None,
                            log_handler=t.log_handler,
                            pipe=pipes.client,
                            fixups=[])

    after 0.5: t.failure(ValueError("Timed out waiting for disabled fixup test"))

actor _test_openconfig_fixup_self_deactivates_after_clean_reply(t: testing.EnvT):
    """Fixup should self-deactivate after first clean relevant reply."""
    pipes = actor_pipe_pair()
    var req_count = 0
    var reply_count = 0

    caps = [
        netconf.CAP_NC_1_0,
        netconf.CAP_NC_1_1,
        "http://openconfig.net/yang/interfaces?module=openconfig-interfaces&revision=2019-11-19",
    ]

    def _request_next(c: netconf.Client):
        c.get_config(_on_get_config)

    def _on_connect(c: netconf.Client, e: ?Exception):
        if e is not None:
            t.failure(ValueError("Connection failed: {e}"))
            return
        _request_next(c)

    def _on_get_config(c: netconf.Client, result: ?xml.Node, error: ?netconf.NetconfError):
        if error is not None:
            t.failure(ValueError("get-config failed: {error}"))
            return
        reply_count += 1
        has_name = has_openconfig_interface_key_name(result)
        has_index = has_openconfig_subinterface_key_index(result)

        if reply_count == 1:
            if not has_name or not has_index:
                t.failure(ValueError("Expected clean OpenConfig keys before deactivation"))
                return
            _request_next(c)
            return

        if reply_count == 2:
            if not has_name and not has_index:
                c.close(None)
                t.success()
            else:
                t.failure(ValueError("Fixup still active after clean-reply deactivation"))
            return

        t.failure(ValueError("Unexpected extra callback"))


    def _on_server_rpc(s: netconf.Server, message_id: str, op: xml.Node):
        if op.tag != "get-config":
            s.send_error(message_id, "operation-not-supported", "Unsupported RPC operation: {op.tag}")
            return
        req_count += 1
        if req_count == 1:
            s.send_reply(message_id, [good_openconfig_interfaces_data()])
        elif req_count == 2:
            s.send_reply(message_id, [broken_openconfig_interfaces_data()])
        else:
            s.send_error(message_id, "operation-not-supported", "Unexpected extra RPC")
    server = netconf.Server(pipe=pipes.server, on_rpc=_on_server_rpc, capabilities=caps, log_handler=t.log_handler)
    client = netconf.Client(t.env.auth,
                            address="actor-pipe",
                            username="actor-pipe",
                            key=None,
                            password=None,
                            port=0,
                            on_connect=_on_connect,
                            on_notif=None,
                            log_handler=t.log_handler,
                            pipe=pipes.client)

    after 1.0: t.failure(ValueError("Timed out waiting for self-deactivation fixup test"))


actor _test_openconfig_fixup_capability_gated(t: testing.EnvT):
    """Default fixup should stay inactive when capability is not advertised."""
    pipes = actor_pipe_pair()

    caps = [netconf.CAP_NC_1_0, netconf.CAP_NC_1_1]

    def _on_connect(c: netconf.Client, e: ?Exception):
        if e is not None:
            t.failure(ValueError("Connection failed: {e}"))
            return
        c.get_config(_on_get_config)

    def _on_get_config(c: netconf.Client, result: ?xml.Node, error: ?netconf.NetconfError):
        if error is not None:
            t.failure(ValueError("get-config failed: {error}"))
            return
        has_name = has_openconfig_interface_key_name(result)
        has_index = has_openconfig_subinterface_key_index(result)
        if not has_name and not has_index:
            c.close(None)
            t.success()
        else:
            t.failure(ValueError("Fixup unexpectedly active without capability"))

    def _on_server_rpc(s: netconf.Server, message_id: str, op: xml.Node):
        if op.tag == "get-config":
            s.send_reply(message_id, [broken_openconfig_interfaces_data()])
        else:
            s.send_error(message_id, "operation-not-supported", "Unsupported RPC operation: {op.tag}")

    server = netconf.Server(pipe=pipes.server, on_rpc=_on_server_rpc, capabilities=caps, log_handler=t.log_handler)
    client = netconf.Client(t.env.auth,
                            address="actor-pipe",
                            username="actor-pipe",
                            key=None,
                            password=None,
                            port=0,
                            on_connect=_on_connect,
                            on_notif=None,
                            log_handler=t.log_handler,
                            pipe=pipes.client)

    after 0.5: t.failure(ValueError("Timed out waiting for capability-gated fixup test"))
